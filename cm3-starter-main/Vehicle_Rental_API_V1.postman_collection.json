          "mode": "raw",
          "raw": "{\n  \"vehicleModel\": \"Honda Accord\",\n  \"category\": \"Sedan\",\n  \"description\": \"Updated description\",\n  \"agency\": {\n    \"name\": \"City Rentals\",\n    \"contactEmail\": \"info@cityrentals.com\",\n    \"fleetSize\": 60\n  },\n  \"location\": {\n    \"city\": \"New York\",\n    \"state\": \"NY\"\n  },\n  \"dailyPrice\": 50,\n  \"availabilityStatus\": \"available\",\n  \"insurancePolicy\": \"Full coverage included\"\n}"
        },
        "url": {
