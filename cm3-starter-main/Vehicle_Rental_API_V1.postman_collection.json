          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"vehicleModel\": \"Toyota Camry\",\n  \"category\": \"Sedan\",\n  \"description\": \"Comfortable sedan for city driving\",\n  \"agency\": {\n    \"name\": \"City Rentals\",\n    \"contactEmail\": \"info@cityrentals.com\",\n    \"fleetSize\": 50\n  },\n  \"location\": {\n    \"city\": \"New York\",\n    \"state\": \"NY\"\n  },\n  \"dailyPrice\": 45,\n  \"availabilityStatus\": \"available\",\n  \"insurancePolicy\": \"Full coverage included\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/vehicleRentals",
          "host": ["{{base_url}}"],
          "path": ["api", "vehicleRentals"]
        }
      }
    },
