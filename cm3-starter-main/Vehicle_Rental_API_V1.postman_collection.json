{
  "info": {
    "name": "Vehicle Rental API V1",
    "description": "CRUD endpoints for VehicleRental resource - No Authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Vehicle Rentals",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/vehicleRentals",
          "host": ["{{base_url}}"],
          "path": ["api", "vehicleRentals"]
        }
      }
    },
    {
      "name": "Get Vehicle Rental by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/vehicleRentals/:id",
          "host": ["{{base_url}}"],
          "path": ["api", "vehicleRentals", ":id"],
          "variable": [
            {
              "key": "id",
              "value": "replace_with_actual_id"
            }
          ]
        }
      }
    },
